generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  firstName       String
  lastName        String
  authId          String              @unique
  npiNumber       String?             @unique
  specialty       String?
  state           String?
  licenseNumber   String?
  role            String              @default("HCP")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  analyticsEvents AnalyticsEvent[]
  cmeCredits      CMECredit[]
  payments        Payment[]
  enrollments     ProgramEnrollment[]
  surveyResponses SurveyResponse[]
  videoViews      VideoView[]

  @@map("User")
}

model Program {
  id                String              @id @default(cuid())
  title             String
  description       String
  thumbnailUrl      String?
  creditAmount      Float
  accreditationBody String?
  status            String              @default("DRAFT")
  sponsorName       String
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  cmeCredits        CMECredit[]
  enrollments       ProgramEnrollment[]
  surveys           Survey[]
  videos            Video[]

  @@map("Program")
}

model Video {
  id          String      @id @default(cuid())
  programId   String
  title       String
  description String?
  platform    String
  videoId     String
  embedUrl    String
  duration    Int
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  program     Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  views       VideoView[]

  @@map("Video")
}

model VideoView {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  watchedSeconds Int      @default(0)
  progress       Float    @default(0)
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("VideoView")
}

model ProgramEnrollment {
  id              String    @id @default(cuid())
  userId          String
  programId       String
  enrolledAt      DateTime  @default(now())
  overallProgress Float     @default(0)
  completed       Boolean   @default(false)
  completedAt     DateTime?
  program         Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("ProgramEnrollment")
}

model Survey {
  id          String           @id @default(cuid())
  programId   String
  title       String
  description String?
  questions   Json
  type        String
  required    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  responses   SurveyResponse[]

  @@map("Survey")
}

model SurveyResponse {
  id          String   @id @default(cuid())
  userId      String
  surveyId    String
  answers     Json
  score       Float?
  submittedAt DateTime @default(now())
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, surveyId])
  @@map("SurveyResponse")
}

model CMECredit {
  id             String    @id @default(cuid())
  userId         String
  programId      String
  credits        Float
  certificateUrl String?
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime?
  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("CMECredit")
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  amount          Float
  stripePaymentId String?
  w9Collected     Boolean   @default(false)
  status          String
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Payment")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  eventName String
  eventData Json
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AnalyticsEvent")
}
