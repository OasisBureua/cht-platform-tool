generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MODEL - Enhanced for payments and activities
// ============================================================================
model User {
  id              String              @id @default(cuid())
  email           String              @unique
  firstName       String
  lastName        String
  authId          String              @unique
  npiNumber       String?             @unique
  specialty       String?
  state           String?
  licenseNumber   String?
  role            String              @default("HCP")
  
  // ADD THESE NEW FIELDS ↓↓↓
  // Stripe Connect integration
  stripeAccountId     String?           // Stripe Connect account ID
  stripeAccountStatus String?           // Status: incomplete, pending, active, rejected
  paymentEnabled      Boolean  @default(false)  // Ready to receive payouts
  w9Submitted         Boolean  @default(false)  // Completed Stripe onboarding
  w9SubmittedAt       DateTime?                 // When completed
  
  // Earnings tracking
  totalEarnings       Int      @default(0)      // Total lifetime earnings (cents)
  activitiesCompleted Int      @default(0)      // Number of completed activities
  // END NEW FIELDS ↑↑↑
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  analyticsEvents AnalyticsEvent[]
  cmeCredits      CMECredit[]
  payments        Payment[]
  enrollments     ProgramEnrollment[]
  surveyResponses SurveyResponse[]
  videoViews      VideoView[]

  @@map("User")
}
// ============================================================================
// PROGRAM MODEL - Enhanced for surveys, payments, and Zoom
// ============================================================================
model Program {
  id                String              @id @default(cuid())
  title             String
  description       String
  thumbnailUrl      String?
  creditAmount      Float
  accreditationBody String?
  status            String              @default("DRAFT")
  sponsorName       String
  startDate         DateTime?
  endDate           DateTime?
  
  // ADD THESE NEW FIELDS ↓↓↓
  // Survey integration (Jotform)
  jotformSurveyId       String?
  jotformSurveyUrl      String?
  requiresSurvey        Boolean         @default(false)
  
  // Payment settings
  honorariumAmount      Int?            // Amount in cents (e.g., 50000 = $500)
  
  // Zoom Events integration
  zoomMeetingId         String?
  zoomMeetingPassword   String?
  zoomJoinUrl           String?
  zoomStartUrl          String?         // For host/KOL
  // END NEW FIELDS ↑↑↑
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  cmeCredits        CMECredit[]
  enrollments       ProgramEnrollment[]
  surveys           Survey[]
  videos            Video[]
  payments          Payment[]

  @@map("Program")
}

// ============================================================================
// VIDEO MODEL - No changes needed
// ============================================================================
model Video {
  id          String      @id @default(cuid())
  programId   String
  title       String
  description String?
  platform    String
  videoId     String
  embedUrl    String
  duration    Int
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  program     Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  views       VideoView[]

  @@map("Video")
}

// ============================================================================
// VIDEO VIEW MODEL - No changes needed
// ============================================================================
model VideoView {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  watchedSeconds Int      @default(0)
  progress       Float    @default(0)
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("VideoView")
}

// ============================================================================
// PROGRAM ENROLLMENT MODEL - No changes needed
// ============================================================================
model ProgramEnrollment {
  id              String    @id @default(cuid())
  userId          String
  programId       String
  enrolledAt      DateTime  @default(now())
  overallProgress Float     @default(0)
  completed       Boolean   @default(false)
  completedAt     DateTime?
  program         Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("ProgramEnrollment")
}

// ============================================================================
// SURVEY MODEL - Enhanced for Jotform integration
// ============================================================================
model Survey {
  id          String           @id @default(cuid())
  programId   String
  title       String
  description String?
  questions   Json
  type        String
  required    Boolean          @default(true)
  
  // ADD THESE NEW FIELDS ↓↓↓
  jotformFormId        String?
  jotformWebhookUrl    String?
  // END NEW FIELDS ↑↑↑
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  responses   SurveyResponse[]

  @@map("Survey")
}

// ============================================================================
// SURVEY RESPONSE MODEL - Enhanced for Jotform tracking
// ============================================================================
model SurveyResponse {
  id          String   @id @default(cuid())
  userId      String
  surveyId    String
  answers     Json
  score       Float?
  
  // ADD THIS NEW FIELD ↓↓↓
  jotformSubmissionId  String?  @unique
  // END NEW FIELD ↑↑↑
  
  submittedAt DateTime @default(now())
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, surveyId])
  @@map("SurveyResponse")
}

// ============================================================================
// CME CREDIT MODEL - No changes needed
// ============================================================================
model CMECredit {
  id             String    @id @default(cuid())
  userId         String
  programId      String
  credits        Float
  certificateUrl String?
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime?
  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("CMECredit")
}

// ============================================================================
// PAYMENT MODEL - Enhanced with type and program relation
// ============================================================================
model Payment {
  id              String        @id @default(cuid())
  userId          String
  programId       String?       // ADD THIS - link to program
  amount          Int           // CHANGE from Float to Int (cents)
  
  // ADD THESE NEW FIELDS ↓↓↓
  type            PaymentType   // Type of payment
  status          PaymentStatus // Payment status
  description     String?       // Payment description
  // END NEW FIELDS ↑↑↑
  
  stripePaymentId String?
  stripePaymentIntentId String? // ADD THIS
  w9Collected     Boolean       @default(false)
  
  // REMOVE this line if it exists:
  // status          String
  
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt  // ADD THIS if missing
  
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         Program?      @relation(fields: [programId], references: [id], onDelete: SetNull) // ADD THIS

  @@index([userId])     // ADD THIS
  @@index([programId])  // ADD THIS
  @@index([status])     // ADD THIS
  @@map("Payment")
}

// ADD THESE ENUMS at the end of the file ↓↓↓
enum PaymentType {
  HONORARIUM        // Payment for program participation
  CME_COMPLETION    // Bonus for completing CME
  SURVEY_BONUS      // Bonus for survey completion
  REFERRAL          // Referral bonus
}

enum PaymentStatus {
  PENDING      // Payment created but not processed
  PROCESSING   // Being processed by Stripe
  PAID         // Successfully paid
  FAILED       // Payment failed
  CANCELLED    // Cancelled by admin
}

// ============================================================================
// ANALYTICS EVENT MODEL - No changes needed
// ============================================================================
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  eventName String
  eventData Json
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AnalyticsEvent")
}