# Required for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cht_platform"

# Optional - defaults work for docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Optional - leave empty for local testing (some features disabled)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=

# Shared CHT auth (GoTrue) - get JWT secret from MediaHub/CHM team
# When set, backend validates JWTs from mediahub.communityhealth.media/auth/v1
GOTRUE_JWT_SECRET=

# Bill.com (payment processing)
BILL_DEV_KEY=
BILL_ORG_ID=
BILL_FUNDING_ACCOUNT_ID=
# Option A: Auto-login (recommended). Session expires after 35 min of inactivity - service auto-refreshes on 401.
BILL_USERNAME=        # Your Bill.com account email
BILL_PASSWORD=        # Your Bill.com account password
# Option B: Manual session (get from POST /v3/login, update when expired)
# BILL_SESSION_ID=
# BILL_API_URL=      # Optional, defaults to sandbox (stage) or prod based on NODE_ENV
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_EMAIL_QUEUE_URL=
SQS_PAYMENT_QUEUE_URL=
SQS_CME_QUEUE_URL=

# Survey bonus payment (cents, 0 = disabled). Sent to payment queue on survey submit.
SURVEY_BONUS_AMOUNT_CENTS=0
