# Required for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cht_platform"

# Optional - defaults work for docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Optional - leave empty for local testing (some features disabled)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=

# Shared CHT auth (GoTrue) - get JWT secret from MediaHub/CHM team
# When set, backend validates JWTs from mediahub.communityhealth.media/auth/v1
GOTRUE_JWT_SECRET=

# Supabase/GoTrue Auth (for backend login validation)
# When set, POST /auth/login and /auth/signup validate via GoTrue
# When empty, dev fallback: lookup by email in DB (password ignored)
# Get valid JWT and secret from MediaHub/CHM team - anon key must be signed with GoTrue secret
SUPABASE_URL=https://mediahub.communityhealth.media
SUPABASE_ANON_KEY=

# Session TTL in seconds (default 1800 = 30 min). Sessions cached in Redis.
SESSION_TTL_SECONDS=1800

# Bill.com (payment processing) - API: https://developer.bill.com/reference/api-reference-overview
# Developer key provided by team (e.g. 01LQJPNSALIQKDZMxxxxxxxx)
BILL_DEV_KEY=
BILL_ORG_ID=
BILL_FUNDING_ACCOUNT_ID=
# Option A: Auto-login (recommended). Session expires after 35 min of inactivity - service auto-refreshes on 401.
BILL_USERNAME=        # Your Bill.com account email
BILL_PASSWORD=        # Your Bill.com account password
# Option B: Manual session (get from POST /v3/login, update when expired)
# BILL_SESSION_ID=
# BILL_API_URL=      # Optional, defaults to sandbox (stage) or prod based on NODE_ENV
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_EMAIL_QUEUE_URL=
SQS_PAYMENT_QUEUE_URL=
SQS_CME_QUEUE_URL=

# Survey bonus payment (cents, 0 = disabled). Sent to payment queue on survey submit.
SURVEY_BONUS_AMOUNT_CENTS=0

# MediaHub Public API (catalog – preferred over YouTube when set)
# Get API key from MediaHub/CHM team
MEDIAHUB_BASE_URL=https://mediahub.communityhealth.media/api/public
MEDIAHUB_API_KEY=

# YouTube Data API v3 (for catalog – fallback when MediaHub not configured).
# Get an API key from Google Cloud Console, enable YouTube Data API v3.
# YOUTUBE_API_KEY=your_api_key
# YOUTUBE_PLAYLIST_IDS=PLxxx,PLyyy   # Comma-separated playlist IDs
# YOUTUBE_PLAYLIST_CSV=data/youtube-playlists.csv   # Or load from CSV file

# Zoom (Server-to-Server OAuth for webinars). Create app at marketplace.zoom.us
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
