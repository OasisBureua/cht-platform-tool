# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cht_platform

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SQS Queue URLs
SQS_EMAIL_QUEUE_URL=
SQS_PAYMENT_QUEUE_URL=
SQS_CME_QUEUE_URL=

# Amazon SES (transactional email - verify domain in SES first)
SES_FROM_EMAIL=noreply@chtplatform.com

# Bill.com
BILL_DEV_KEY=
BILL_FUNDING_ACCOUNT_ID=
# Option A: Auto-login (recommended). Set BILL_USERNAME, BILL_PASSWORD, BILL_ORG_ID.
# BILL_USERNAME=
# BILL_PASSWORD=
# BILL_ORG_ID=
# Option B: Manual session (expires after 35 min)
# BILL_SESSION_ID=

# S3 (for certificates)
S3_CERTIFICATES_BUCKET=cht-platform-certificates-dev

# Environment
ENVIRONMENT=development
