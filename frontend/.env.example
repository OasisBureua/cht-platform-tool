# Required: Backend API base URL (include /api)
VITE_API_URL=http://localhost:3000/api

# Shared CHT auth (GoTrue at mediahub.communityhealth.media)
# Defaults work for production - override if needed
# VITE_SUPABASE_URL=https://mediahub.communityhealth.media
# VITE_SUPABASE_ANON_KEY=public

# Dev bypass: set to true to use X-Dev-User-Id instead of Supabase
# VITE_USE_DEV_AUTH=false

# When VITE_USE_DEV_AUTH=true: run "cd backend && npx prisma db seed" then copy user ID
# VITE_DEV_USER_ID=<user-id-from-seed>