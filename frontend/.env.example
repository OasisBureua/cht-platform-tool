# Required: Backend API base URL (include /api)
# Must match where your backend runs. Use 127.0.0.1 if localhost fails.
VITE_API_URL=http://localhost:3000/api

# Shared CHT auth (GoTrue at mediahub.communityhealth.media)
# For local Supabase login - ensure URL is reachable from your machine
# VITE_SUPABASE_URL=https://mediahub.communityhealth.media
# VITE_SUPABASE_ANON_KEY=public

# Dev bypass: set to true to skip Supabase - avoids "Failed to fetch" when auth server unreachable
#VITE_USE_DEV_AUTH=true

# When VITE_USE_DEV_AUTH=true: run "cd backend && npx prisma db seed" then paste user ID here
# VITE_DEV_USER_ID=

# Set to true once to clear stored cht-dev-user-id, then reload and unset (dev auth only)
# VITE_CLEAR_DEV_AUTH=true

# Bypass auth entirely - browse /app and /admin without logging in (dev only)
# VITE_DISABLE_AUTH=true