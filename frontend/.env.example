# Required: Backend API base URL (include /api)
# Must match where your backend runs. Use 127.0.0.1 if localhost fails.
VITE_API_URL=http://localhost:3000/api

# Shared CHT auth (GoTrue at mediahub.communityhealth.media/auth/v1)
# REQUIRED: Get valid JWT anon key from MediaHub/CHM team - must be signed with GoTrue secret
VITE_SUPABASE_URL=https://mediahub.communityhealth.media
VITE_SUPABASE_ANON_KEY=

# OAuth redirect base URL - MUST be in GoTrue's Redirect URLs allowlist.
# Set to your CHT platform URL (e.g. https://testapp.communityhealth.media) so Google/Apple sign-in
# redirects back here instead of MediaHub. If unset, uses window.location.origin.
# VITE_APP_URL=https://testapp.communityhealth.media

# Bypass Supabase auth (dev only):
# Option A: Skip route guards - set to true to open /app and /admin without logging in.
# Login / Admin Sign In still work: submit the form once to set a mock session and redirect (no API call).
VITE_DISABLE_AUTH=false

# Option B: Use dev login (no Supabase) - backend must NOT have SUPABASE_URL/SUPABASE_ANON_KEY set.
# Run: cd backend && npx prisma db seed
# Then login with: dev@chtplatform.local / any-password-8chars
VITE_USE_DEV_AUTH=true
VITE_DEV_USER_ID=