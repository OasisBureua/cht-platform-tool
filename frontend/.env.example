# Required: Backend API base URL (include /api)
# Must match where your backend runs. Use 127.0.0.1 if localhost fails.
VITE_API_URL=http://localhost:3000/api

# Shared CHT auth (GoTrue at mediahub.communityhealth.media/auth/v1)
# Get valid JWT anon key from MediaHub/CHM team - "public" is not a valid JWT
VITE_SUPABASE_URL=https://mediahub.communityhealth.media
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzA2NzQ1NjAwLCJleHAiOjE4NjQ1MTIwMDB9.bNuR9BoKqMlWQJKTcECGf59hVyj2MZGs0aKbBNAExtM

# Bypass auth entirely - browse /app and /admin without logging in (dev only)
VITE_DISABLE_AUTH=false

# Dev bypass: false = use real Supabase login
VITE_USE_DEV_AUTH=true

# When VITE_USE_DEV_AUTH=true: run "cd backend && npx prisma db seed" then paste user ID here
VITE_DEV_USER_ID=

# Backend validates login via Supabase when SUPABASE_URL/SUPABASE_ANON_KEY set.
# When not set, backend uses dev fallback (lookup by email in DB, run: cd backend && npx prisma db seed).