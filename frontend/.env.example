# Required: Backend API base URL (include /api)
VITE_API_URL=http://localhost:3000/api

# Auth0 (when configured - omit for dev mode with X-Dev-User-Id)
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=your_client_id
# VITE_AUTH0_AUDIENCE=your_api_audience

# Dev mode only: run "cd backend && npx prisma db seed" then copy user ID here
#VITE_DEV_USER_ID=<user-id-from-seed>
#VITE_DEV_ADMIN_USER_ID=<admin-id-from-seed>